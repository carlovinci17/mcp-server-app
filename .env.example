# Copy to .env for running scripts/tests locally outside of `func start`.
# When running via `func start`, these same keys belong in local.settings.json "Values" instead.

ENVIRONMENT=local

# Azure SQL Database (server + database name; auth is via DefaultAzureCredential, no password here)
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=enterprise-knowledge-db

# Azure Blob Storage (account URL; auth is via DefaultAzureCredential)
AZURE_STORAGE_ACCOUNT_URL=https://youraccount.blob.core.windows.net

# Azure AI Search (leave unset to disable search tools in local dev)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=enterprise-knowledge-index

# Azure OpenAI (embeddings for vector search; leave unset to disable semantic_search)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure Key Vault (leave unset to disable Key Vault-backed secrets in local dev)
AZURE_KEY_VAULT_URL=

# Azure App Configuration (leave unset to fall back to config/settings.yaml only)
AZURE_APPCONFIG_ENDPOINT=

# Application Insights (leave unset to disable telemetry export in local dev)
APPLICATIONINSIGHTS_CONNECTION_STRING=
